filters:
  or:
    - file.tags.contains("obsidian")
    - file.links.contains("obsidian")
views:
  - type: table
    name: Table
    order:
      - file.name
      - file.backlinks
    sort:
      - property: file.backlinks
        direction: DESC
    columnSize:
      file.name: 394
      file.backlinks: 327
